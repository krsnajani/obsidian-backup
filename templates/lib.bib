@online{akarYouHaveBeen2022,
  type = {SSRN Scholarly Paper},
  title = {You {{Have Been Terminated}}: {{Robot Taxation}} and the {{Welfare State}}},
  shorttitle = {You {{Have Been Terminated}}},
  author = {Akar, Gizem and Casalone, Giorgia and Zagler, Martin},
  date = {2022-02-01},
  number = {4040134},
  eprint = {4040134},
  eprinttype = {Social Science Research Network},
  location = {Rochester, NY},
  doi = {10.2139/ssrn.4040134},
  url = {https://papers.ssrn.com/abstract=4040134},
  urldate = {2026-03-27},
  abstract = {We present a three sector OLG model with a homogenous output good that is produced with traditional or robot technology. The traditional sector produces with labor and capital, whereas the modern sector employs robots instead of labor. We find that little can prevent the ascent of a modern economy. In particular, whilst robots are perfect substitutes to labor in our model, it is only the ratio of robot to capital taxes that can influence the speed of transition. The robotics sector produces robots using the homogeneous output good. We find that wages fall with a relative increase in productivity in the modern sector and a decrease in market power of robot suppliers. Falling wages imply that consumption will fall through generations, and a utilitarian government would feel inclined to intervene. We present several welfare policies, from wage subsidies, unemployment benefits, pensions, to a universal basic income. We also show under which conditions, as the economy becomes fully roboterized, it will switch from an exogenous growth model based on TFP to an endogenous growth model due to constant returns with respect to reproducible factors of production.},
  langid = {english},
  pubstate = {prepublished},
  keywords = {Economic Growth,Robot Taxation,Robots,Singularity},
  file = {/Users/krishnajani/Library/CloudStorage/OneDrive-Personal/Attachments/Akar et al. - 2022 - You Have Been Terminated Robot Taxation and the Welfare State.pdf}
}

@article{alissaComparativeStudyWhatsApp2019,
  title = {A Comparative Study of {{WhatsApp}} Forensics Tools},
  author = {Alissa, Khalid and Almubairik, Norah A. and Alsaleem, Lamyaa and Alotaibi, Deema and Aldakheel, Malak and Alqhtani, Sarah and Saqib, Nazar and Brahimi, Samiha and Alshahrani, Mubarak},
  date = {2019-11},
  journaltitle = {SN Applied Sciences},
  shortjournal = {SN Appl. Sci.},
  volume = {1},
  number = {11},
  pages = {1320},
  issn = {2523-3963, 2523-3971},
  doi = {10.1007/s42452-019-1312-8},
  url = {http://link.springer.com/10.1007/s42452-019-1312-8},
  urldate = {2025-06-29},
  abstract = {With the increasing number of mobile phones and mobile applications, there is a noticeable rise in cybercrimes. Hence, an urgent need for mobile forensics. Before starting investigation, the investigator should choose one of the acquisition types; physical acquisition, logical acquisition or manual acquisition. The current mobile acquisition tools use these methods to produce an image of the entire mobile content, files of specific datatypes, or data of a certain application. Unfortunately, the resultant output does not facilitate investigating cases related to specific mobile application, since the tool might acquire more than what is needed which requires investigators to filter data manually, or acquire all the application’s data without sufficient analysis. Both cases are effort and time consuming. This study analyzes and compares currently available forensics tools that are designed to extract WhatsApp data only. The comparative study is based on two aspects; National Institute of Standards and Technology (NIST) Mobile Device Tool Test Assertions and researchers’ requirements. The results of the comparative study showed a shortage in the current WhatsApp forensics tools as they do not satisfy all NIST Test Assertions. Additionally, several researchers’ requirements such as: creating projects, comprehensive analysis, applying filters and validating the extracted files, were not met in the studied tools.},
  langid = {english},
  file = {/Users/krishnajani/Library/CloudStorage/GoogleDrive-krishnajani2005@gmail.com/My Drive/Research Papers/Alissa et al. - 2019 - A comparative study of WhatsApp forensics tools 1.pdf}
}

