@incollection{salveInterStateRiverWater2016,
  title = {Inter-{{State River Water Disputes}}},
  booktitle = {The {{Oxford Handbook}} of the {{Indian Constitution}}},
  author = {Salve, Harish},
  editor = {Choudhry, Sujit and Khosla, Madhav and Bhanu Mehta, Pratap},
