  title = {Aromanticism, Asexuality, and Relationship (Non-)Formation: {{How}} a-Spec Singles Challenge Romantic Norms and Reimagine Family Life},
  shorttitle = {Aromanticism, Asexuality, and Relationship (Non-)Formation},
  author = {Tessler, Hannah},
  date = {2025-02},
  journaltitle = {Sexualities},
