@article{smithGSTSecureSource,
  title = {{{GST}} as a Secure Source of Revenue for the {{States}} and {{Territories}}},
  author = {Smith, Greg},
  abstract = {Goods and services tax (GST) revenues collected by the Commonwealth Government in Australia are provided in full as untied revenue grants to the State and Territory governments. The hypothecation of GST revenues in this way provides a reasonably secure foundation for federal financial relations in Australia. However, Australia’s federation has been marked by continuing change in the vertical sharing of government functions, costs and revenues, and State fiscal security is potentially vulnerable in these changing circumstances. The advantages and disadvantages of the GST revenue arrangements have themselves changed over time since the GST was introduced in 2000, with implications both for the GST as a tax and for the evolution of the Australian federation. This article discusses these developments and some possible future directions.},
  langid = {english},
  file = {/Users/krishnajani/Library/CloudStorage/OneDrive-Personal/Attachments/Smith - GST as a secure source of revenue for the States and Territories.pdf}
}

