@inproceedings{lancellottiDesignQuantumWalk2024a,
  title = {Design of a {{Quantum Walk Circuit}} to {{Solve}} the {{Subset-Sum Problem}}},
  booktitle = {Proceedings of the 61st {{ACM}}/{{IEEE Design Automation Conference}}},
  author = {Lancellotti, Giacomo and Perriello, Simone and Barenghi, Alessandro and Pelosi, Gerardo},
  date = {2024-06-23},
  pages = {1--6},
  publisher = {ACM},
  location = {San Francisco CA USA},
  doi = {10.1145/3649329.3657337},
  url = {https://dl.acm.org/doi/10.1145/3649329.3657337},
  urldate = {2025-10-11},
  abstract = {Search algorithms based on quantum walks have emerged as a promising approach to solve computational problems across various domains, including combinatorial optimization, and cryptography. Stating a generic search problem in terms of a (quantum) search over a graph makes the efficiency of the algorithmic method depend on the structure of the graph itself. In this work, we propose a complete implementation of a quantum walk search on Johnson graphs, speeding up the solution of the subset-sum problem. We provide a detailed design of each sub-circuit, quantifying their cost in terms of gate number, depth, and width. We compare our solution against a Grover quantum search, showing a reduction of the Tcount and T-depth for practically solvable problems. The proposed design provides a building block for the construction of efficient quantum search algorithms that can be modelled on Johnson graphs, filling the gap with the existing theoretical complexity analyses.},
  eventtitle = {{{DAC}} '24: 61st {{ACM}}/{{IEEE Design Automation Conference}}},
  isbn = {979-8-4007-0601-1},
  langid = {english},
  file = {/Users/krishnajani/Library/CloudStorage/OneDrive-Personal/Attachments/Lancellotti et al. - 2024 - Design of a Quantum Walk Circuit to Solve the Subset-Sum Problem 1.pdf}
}

