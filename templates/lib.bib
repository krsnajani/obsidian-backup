@article{mullerConstitutionalPatriotismIntroduction12008,
  title = {Constitutional Patriotism: {{An}} Introduction1},
  shorttitle = {Constitutional Patriotism},
  author = {Müller, Jan-Werner and Scheppele, Kim Lane},
  date = {2008-01-01},
  journaltitle = {International Journal of Constitutional Law},
  shortjournal = {International Journal of Constitutional Law},
  volume = {6},
  number = {1},
  pages = {67--71},
  issn = {1474-2640},
  doi = {10.1093/icon/mom039},
  url = {https://doi.org/10.1093/icon/mom039},
  urldate = {2024-04-27},
  abstract = {Constitutional patriotism is one of the most attractive yet ill-defined ideas in modern political theory. The idea has become most closely associated with Jürgen Habermas and his attempt to propose a plausible form of collective identification for a postnational Germany and for the European Union.2 But Habermas's explanations have been criticized as too abstract, insufficiently endowed with specific content, and yet, somehow, also too specifically German.3 Though, no doubt, Habermas will continue to be extremely influential in the history of this particular idea, we present here a sustained discussion of alternative views of constitutional patriotism in hopes of both liberating it from Habermas's specific conception and opening up a more general discussion about constitutional patriotism. The extent to which the idea has been embraced, even in the absence of a single coherent account, suggests that many find it useful in various legal and political contexts. We include in this symposium several systematic approaches for thinking about it.},
  file = {/home/krishnaj/docs/paper_lib/Müller_Scheppele_2008_Constitutional patriotism.pdf;/home/krishnaj/docs/paper_lib/Müller_Scheppele_2008_Constitutional patriotism2.pdf;/home/krishnaj/docs/paper_lib/Müller_Scheppele_2008_Constitutional patriotism3.pdf;/home/krishnaj/docs/paper_lib/669061.html}
}

@article{mullerOriginsConstitutionalPatriotism2006,
  title = {On the {{Origins}} of {{Constitutional Patriotism}}},
  author = {Müller, Jan-Werner},
  date = {2006-08-01},
  journaltitle = {Contemporary Political Theory},
  shortjournal = {Contemp Polit Theory},
  volume = {5},
  number = {3},
  pages = {278--296},
  issn = {1476-9336},
  doi = {10.1057/palgrave.cpt.9300235},
  url = {https://doi.org/10.1057/palgrave.cpt.9300235},
  urldate = {2024-04-27},
  abstract = {Political theorists tend to dismiss the concept of constitutional patriotism for two main reasons. On the one hand, constitutional patriotism — understood as a post-national, universalist form of democratic political allegiance — is rejected on account of its abstract quality. On the otherhand, it is argued that constitutional patriotism, while apprearing universalist, is in fact particular through and through. According to this genealogical critique, it is held that constitutional patriotism might have been appropriate in the context when it originated — namely West Germany, a half-nation with a deeply compromised sense of nationality on account of the Nazi past — but it is not universally applicable. This article reconstructs the origins of constitutional patriotism arguing that both the ‘protective’ and state-centred patriotism of Dolf Sternberger, and the ‘purifying’ patriotism of Jurgen Habermas — focused mainly on the public sphere — can indeed be understood as relying on ‘supplements of particularily’. However, there are also normative connections between universalist constitutional morality and militant democracy on the one hand, and universalist constitutionalist morality and an imperative to remember on the other. Thus, the genealogical critique by itself is insufficient to invalidate the idea of constitutional patriotism.},
  langid = {english},
  keywords = {constitutional patriotism,Dolf Sternberger,ethics of remembrance,Jürgen Habermas,liberal nationalism,militant democray},
  file = {/home/krishnaj/docs/paper_lib/Müller_2006_On the Origins of Constitutional Patriotism.pdf;/home/krishnaj/docs/paper_lib/Müller_2006_On the Origins of Constitutional Patriotism2.pdf}
}

