@article{yorgasonCampaignFinanceVouchers2025,
  title = {Campaign {{Finance Vouchers Do Not Expand}} the {{Diversity}} of {{Donors}}: {{Evidence}} from {{Seattle}}},
  shorttitle = {Campaign {{Finance Vouchers Do Not Expand}} the {{Diversity}} of {{Donors}}},
  author = {Yorgason, Chenoa},
  date = {2025-02},
  journaltitle = {American Political Science Review},
  shortjournal = {Am Polit Sci Rev},
  volume = {119},
  number = {1},
  pages = {508--516},
  issn = {0003-0554, 1537-5943},
  doi = {10.1017/S0003055424000170},
  url = {https://www.cambridge.org/core/product/identifier/S0003055424000170/type/journal_article},
  urldate = {2025-06-23},
  abstract = {Abstract             Donating to a campaign is inherently costly, and as a result the composition of campaign donors differs from the composition of the electorate. What happens when the financial barriers to campaign finance participation are removed? This paper analyzes Seattle’s recent campaign finance reform, where all registered voters receive four \$25 vouchers to donate to candidates abiding by stricter campaign finance restrictions. Utilizing individual- and census block group-level data combined with administrative donation records, I find that those most mobilized by the availability of vouchers belong to groups already overrepresented within the donor pool. This finding is significant across race, income, past political participation, age, and partisanship. In some cases, the availability of vouchers appears to pull the donor pool further from parity with the larger electorate.},
  langid = {english},
  file = {/Users/krishnajani/Library/CloudStorage/GoogleDrive-krishnajani2005@gmail.com/My Drive/Research Papers/Yorgason - 2025 - Campaign Finance Vouchers Do Not Expand the Diversity of Donors Evidence from Seattle.pdf}
}

