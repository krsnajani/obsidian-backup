@article{snipesSuccessiveThreatTheory2020,
  title = {A {{Successive Threat Theory}} of {{Police Expenditures}}},
  author = {Snipes, Jeffrey B. and Maguire, Edward R. and Wang, Xia},
  date = {2020-10},
  journaltitle = {Crime \& Delinquency},
  shortjournal = {Crime \& Delinquency},
  volume = {66},
