@online{xiongGlobalTrendsCryptocurrency2024,
  title = {Global {{Trends}} in {{Cryptocurrency Regulation}}: {{An Overview}}},
  shorttitle = {Global {{Trends}} in {{Cryptocurrency Regulation}}},
  author = {Xiong, Xihan and Luo, Junliang},
