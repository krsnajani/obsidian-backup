  title = {India’s {{Social Stock Exchange}} ({{ISSE}}) – {{A}} 360° {{Analysis}} - {{Today}}’s Commitment for Tomorrow’s Action},
  author = {Patel, C. S. Divyesh and Patel, Naresh K.},
  date = {2023-07-03},
  journaltitle = {Journal of Sustainable Finance \& Investment},
  shortjournal = {Journal of Sustainable Finance \& Investment},
  volume = {13},
